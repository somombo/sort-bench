{
  "components": {
    "bun": {
      "type": "executor",
      "command": "bun",
      "args": [
        "run",
        "./main.js"
      ],
      "working_dir": "components/exec-javascript_sorter"
    },
    "c": {
      "type": "executor",
      "command": "./sorter_c_exe",
      "working_dir": "components/exec-c_sorter"
    },
    "cpp": {
      "type": "executor",
      "command": "./sorter_cpp_exe",
      "working_dir": "components/exec-cpp_sorter"
    },
    "csharp": {
      "type": "executor",
      "command": "dotnet",
      "args": [
        "bin/Release/net9.0/publish/AlgoCSharpSorter.dll"
      ],
      "working_dir": "components/exec-csharp_sorter"
    },
    "deno": {
      "type": "executor",
      "command": "deno",
      "args": [
        "run",
        "--allow-sys",
        "./main.js"
      ],
      "working_dir": "components/exec-javascript_sorter"
    },
    "golang": {
      "type": "executor",
      "command": "./sorter_go_exe",
      "working_dir": "components/exec-go_sorter"
    },
    "java": {
      "type": "executor",
      "command": "java",
      "args": [
        "-server",
        "-XX:+UseParallelGC",
        "-XX:+AlwaysPreTouch",
        "-XX:+UseNUMA",
        "Sorter"
      ],
      "working_dir": "components/exec-java_sorter"
    },
    "lean": {
      "type": "executor",
      "command": ".lake/build/bin/sorter_lean",
      "working_dir": "components/exec-lean_sorter"
    },
    "nodejs": {
      "type": "executor",
      "command": "node",
      "args": [
        "main.js"
      ],
      "working_dir": "components/exec-javascript_sorter"
    },
    "ocaml": {
      "type": "executor",
      "command": "./sorter_ocaml_exe",
      "working_dir": "components/exec-ocaml_sorter"
    },
    "python": {
      "type": "executor",
      "command": "uv",
      "args": [
        "run",
        "main.py"
      ],
      "working_dir": "components/exec-python_sorter"
    },
    "rust": {
      "type": "executor",
      "command": "target/release/algo-rust_sorter",
      "working_dir": "components/exec-rust_sorter"
    },
    "somombo_unifshuffle": {
      "type": "generator",
      "command": ".lake/build/bin/data_generator",
      "working_dir": "components/gen_somombo_unifshuffle"
    },
    "somombo_unifshuffle_multi": {
      "type": "generator",
      "command": ".lake/build/bin/data_generator_multi",
      "working_dir": "components/gen_somombo_unifshuffle"
    },
    "zig": {
      "type": "executor",
      "command": "zig-out/bin/sorter_zig_exe",
      "working_dir": "components/exec-zig_sorter"
    }
  }
}